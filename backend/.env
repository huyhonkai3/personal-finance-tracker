# =============================================
# CẤU HÌNH MÔI TRƯỜNG - PERSONAL FINANCE TRACKER
# =============================================
# KHÔNG COMMIT file .env lên Git (đã có trong .gitignore)

# Cổng server sẽ chạy
PORT=5000

# Chuỗi kết nối MongoDB
# Ví dụ local:  mongodb://localhost:27017/finance_tracker
# Ví dụ Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance_tracker
MONGO_URI=mongodb://localhost:27017/finance_tracker

# Môi trường chạy: development | production | test
NODE_ENV=development
